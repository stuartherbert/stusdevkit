{
    "name": "stusdevkit/stusdevkit",
    "description": "Type-safe collection, list and index classes",
    "type": "library",
    "license": "BSD-3-Clause",
    "autoload": {
        "files": [
            "kits/missingbitskit/src/object_merge.php"
        ],
        "psr-4": {
            "StusDevKit\\ChangelogTool\\": "tools/ChangelogTool/src/",
            "StusDevKit\\CollectionsKit\\": "kits/collectionskit/src/",
            "StusDevKit\\DateTimeKit\\": "kits/datetimekit/src/",
            "StusDevKit\\AssertionsKit\\": "kits/assertionskit/src/",
            "StusDevKit\\ExceptionsKit\\": "kits/exceptionskit/src/",
            "StusDevKit\\ValidationKit\\": "kits/validationkit/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StusDevKit\\ChangelogTool\\Tests\\Unit\\": "tools/ChangelogTool/tests/unit/src",
            "StusDevKit\\ChangelogTool\\Tests\\Fixtures\\": "tools/ChangelogTool/tests/fixtures/src",
            "StusDevKit\\CollectionsKit\\Tests\\Unit\\": "kits/collectionskit/tests/unit/src",
            "StusDevKit\\CollectionsKit\\Tests\\Fixtures\\": "kits/collectionskit/tests/fixtures/src",
            "StusDevKit\\DateTimeKit\\Tests\\Unit\\": "kits/datetimekit/tests/unit/src",
            "StusDevKit\\DateTimeKit\\TestFixtures\\": "kits/datetimekit/tests/fixtures/src",
            "StusDevKit\\AssertionsKit\\Tests\\Unit\\": "kits/assertionskit/tests/unit/src",
            "StusDevKit\\AssertionsKit\\Tests\\Fixtures\\": "kits/assertionskit/tests/fixtures/src",
            "StusDevKit\\ExceptionsKit\\Tests\\Unit\\": "kits/exceptionskit/tests/unit/src",
            "StusDevKit\\ExceptionsKit\\TestFixtures\\": "kits/exceptionskit/tests/fixtures/src",
            "StusDevKit\\ValidationKit\\Tests\\Acceptance\\": "kits/validationkit/tests/acceptance/src",
            "StusDevKit\\ValidationKit\\Tests\\Unit\\": "kits/validationkit/tests/unit/src",
            "StusDevKit\\ValidationKit\\Tests\\Fixtures\\": "kits/validationkit/tests/fixtures/src",
            "StusDevKit\\MissingBitsKit\\Tests\\Unit\\": "kits/missingbitskit/tests/unit/src",
            "StusDevKit\\MissingBitsKit\\Tests\\Fixtures\\": "kits/missingbitskit/tests/fixtures/src"
        }
    },
    "bin": ["tools/ChangelogTool/bin/changelog-tool"],
    "authors": [
        {
            "name": "Stuart Herbert",
            "email": "stuart@stuartherbert.com"
        }
    ],
    "require": {
        "phpstan/phpstan": "^2.1.38",
        "ramsey/uuid": "^4.9"
    },
    "require-dev": {
        "laminas/laminas-coding-standard": "^3.1",
        "phpunit/phpunit": "^13.0",
        "roave/security-advisories": "dev-latest"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
